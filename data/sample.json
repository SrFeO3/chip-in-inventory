      "routingChains": [
        {
          "name": "fruit-shop-route",
          "title": "Routing-Chain fruit-shop-route",
          "description": "Virtual host handling 'fruit' subdomain requests",
          "rules": [
            {
              "match": "request.path == '/set-device-id'",
              "action": {
                "type": "setDeviceId",
                "expiration": null
              }
            },
            {
              "match": "request.path == '/checkout'",
              "action": {
                "type": "checkoutServices"
              }
            },
            {
              "match": "request.path.starts_with('/proxy/')",
              "action": {
                "type": "proxy",
                "target": "http://backend-service.internal"
              }
            },
            {
              "match": "request.path == '/redirect'",
              "action": {
                "type": "redirect"
              }
            },
            {
              "match": "request.path == '/jump'",
              "action": {
                "type": "jump"
              }
            },
            {
              "match": "request.path == '/set-vars'",
              "action": {
                "type": "setVariables"
              }
            },
            {
              "match": "request.path == '/set-headers'",
              "action": {
                "type": "setHeaders"
              }
            },
            {
              "match": "request.path.starts_with('/admin/')",
              "action": {
                "type": "authentication"
              }
            }
          ],
          "createdAt": "2025-11-28T07:38:06.054889192Z",
          "updatedAt": "2025-12-02T07:24:37.252441710Z"
        }
      ]
    }
